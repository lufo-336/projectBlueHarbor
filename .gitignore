# ==========================================================================
# BlueHarbor Terminal — .gitignore
# Copre: backend .NET / C# (Visual Studio) + frontend React/Node + SQL + OS
# ==========================================================================

# --- File personali / sensibili (NON pubblicare sul repo condiviso) ---
# Contesto personale di corso (email, avanzamento moduli) — tenere locale
documentazione/claude/CLAUDE.md
# Documento didattico marcato "Sensitivity: Internal"
documentazione/WSA_Piano-didattico_GAANT.pdf
# Schede operative degli sprint per Trello (uso interno, non nel repo)
documentazione/claude/sprint/

# ==========================================================================
# Backend — .NET / C# / Visual Studio   (cartella /backend)
# ==========================================================================
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
.vs/
*.user
*.suo
*.userprefs
project.lock.json
artifacts/

# Segreti / configurazioni locali (connection string, ecc.)
appsettings.Development.json
appsettings.Local.json
*.local.json
secrets.json

# ==========================================================================
# Frontend — Node / React / Vite   (cartella /frontend)
# ==========================================================================
node_modules/
dist/
build/
.vite/
coverage/

# Variabili d'ambiente
.env
.env.*
!.env.example

# Log dei package manager
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================================
# Database — SQL Server
# ==========================================================================
*.mdf
*.ldf
*.ndf
*.bak

# ==========================================================================
# Sistema operativo / editor
# ==========================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
*.swp
*~

# Editor (VS Code: tieni le impostazioni condivise, ignora il resto)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
